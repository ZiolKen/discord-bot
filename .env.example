# Discord
TOKEN=
CLIENT_ID=

# Optional defaults (guild-specific settings are stored in DB)
# PREFIX=!

# PostgreSQL shards
# You can use DATABASE_URL (single shard) OR DATABASE_URL-1 / DATABASE_URL-2 ...
DATABASE_URL-1=
PG_CA_PATH-1=/etc/secrets/ca.pem
# PG_CA-1="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# DATABASE_URL-2=
# PG_CA_PATH-2=/etc/secrets/ca2.pem

# SSL
PG_SSL_MODE=verify-ca
# PG_SSL_MODE=auto            # convenient for local dev if using localhost
# PG_SSL_DISABLE=1            # force disable SSL (not recommended for prod)

# Pool
PG_POOL_MAX=5

# Economy tuning
# DAILY_BASE=30
# WEEKLY_BASE=150
# DAILY_COOLDOWN_HOURS=24
# DAILY_STREAK_GRACE_HOURS=48
# WEEKLY_COOLDOWN_DAYS=7
# WEEKLY_STREAK_GRACE_DAYS=14

# Gathering cooldowns
# FISH_COOLDOWN_MIN=10
# HUNT_COOLDOWN_MIN=30

# Market fee (burned from each purchase; seller receives total - fee)
# MARKET_FEE_PCT=3
# MARKET_FEE_MIN_TOTAL=100
# MARKET_FEE_MIN=1
